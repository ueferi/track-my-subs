{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"jsx": "react-jsx",
		"lib": ["ES2021", "DOM", "DOM.Iterable"],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"outDir": "dist",
		"types": ["vite/client"],
		"paths": {
			"@/*": ["./src/*"],
			"@shared/*": ["../shared/src/*"]
		}
	},
	"include": ["src"],
	"references": [{ "path": "../shared" }]
}
